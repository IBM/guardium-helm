# =============================================================================
# Guardium VA Scanner — Docker Compose Configuration
# =============================================================================
# Copy this file to .env and fill in all required values.
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains sensitive credentials.
# =============================================================================


# =============================================================================
# Scanner Image Configuration
# Mirrors: image.repository / image.tag in values.yaml
# =============================================================================
IMAGE_REPOSITORY=cp.icr.io/cp/ibm-guardium-data-security-center/guardium/vascanner-12.2.0/va-scanner
IMAGE_TAG=vascanner-v12.2.0


# =============================================================================
# Registry Configuration
# Mirrors: registry.* in values.yaml
#
# Before running docker compose, authenticate with the registry:
#   docker login cp.icr.io -u cp -p <REGISTRY_PASSWORD>
# =============================================================================
REGISTRY_SERVER=cp.icr.io
REGISTRY_USERNAME=cp
REGISTRY_PASSWORD=REPLACE_WITH_IBM_ENTITLEMENT_KEY   # https://myibm.ibm.com/products-services/containerlibrary
REGISTRY_EMAIL=cp


# =============================================================================
# GDP (Guardium Data Protection) Configuration
# Mirrors: gdp.* in values.yaml
# =============================================================================

# GDP Server hostname — MUST match the hostname in your SSL certificate.
#
# Check your certificate hostname:
#   openssl s_client -connect YOUR_GDP_SERVER:8443 -showcerts </dev/null 2>/dev/null \
#     | openssl x509 -noout -text | grep -A2 "Subject Alternative Name"
#
# Use the DNS name from the certificate output (e.g. guard.yourcompany.com).
GDP_HOST=guard.yourcompany.com

# Mirrors: gdp.hostPort
GDP_HOST_PORT=8443

# Mirrors: gdp.agentPort
GDP_AGENT_PORT=8443

# GDP API Key (base64 encoded).
# Mirrors: gdp.apiKey
#
# Generate on the GDP server:
#   grdapi create_api_key name=vascannervm
# Copy the "Encoded API key" value from the output.
GDP_API_KEY=REPLACE_WITH_BASE64_API_KEY

# VA Agent Name — unique identifier for this scanner instance.
# Mirrors: gdp.agentName
GDP_AGENT_NAME=vm-va-scanner-01

# Polling interval in minutes. Keeps the scanner running between jobs.
# Mirrors: vaScannerPollInMins
# Recommended: 5–15 minutes. Set to 0 to disable (scanner exits after each run).
VA_SCANNER_POLL_IN_MINS=5


# =============================================================================
# SSL Certificate
# Mirrors: gdp.certBase64 in values.yaml
#
# Decode your base64 certificate into the certs/ directory:
#
#   Step 1 — Fetch and encode the GDP certificate:
#     openssl s_client -connect YOUR_GDP_SERVER:8443 -showcerts </dev/null 2>/dev/null \
#       | openssl x509 -outform PEM | base64 | tr -d '\n'
#
#   Step 2 — Decode into the certs/ directory:
#     echo "PASTE_BASE64_CERT_HERE" | base64 -d > certs/vascanner.pem
#
# The file must exist at certs/vascanner.pem before running docker compose.
# =============================================================================


# =============================================================================
# Host Aliases — DNS override for certificate hostname resolution
# Mirrors: hostAliases in values.yaml
#
# ONLY required when your GDP certificate hostname differs from the server IP/DNS.
#
# Example scenario:
#   - GDP server IP:         52.21.60.157
#   - Certificate hostname:  guard.yourcompany.com
#   → Set GDP_HOST_ALIAS_IP=52.21.60.157
#
# If your certificate hostname resolves correctly via DNS, leave this blank.
# =============================================================================
GDP_HOST_ALIAS_IP=


# =============================================================================
# Optional: Alternative Authentication
# Mirrors: gdp.username / gdp.clientId / gdp.clientPassword / gdp.clientSecret
# Leave blank if using API key authentication (recommended).
# =============================================================================
GDP_USERNAME=
GDP_CLIENT_ID=
GDP_CLIENT_PASSWORD=
GDP_CLIENT_SECRET=


# =============================================================================
# Optional: Proxy Configuration
# Mirrors: gdp.httpProxyIp / gdp.httpProxyPort
# =============================================================================
GDP_HTTP_PROXY_IP=
GDP_HTTP_PROXY_PORT=


# =============================================================================
# Optional: Cloud Resource Name
# Mirrors: gdp.cloudResourceName
# =============================================================================
GDP_CLOUD_RESOURCE_NAME=


# =============================================================================
# Resource Limits
# Mirrors: resources.limits / resources.requests in values.yaml
# =============================================================================
RESOURCES_LIMITS_CPU=1.0
RESOURCES_LIMITS_MEMORY=2g
RESOURCES_REQUESTS_CPU=0.25
RESOURCES_REQUESTS_MEMORY=512m
